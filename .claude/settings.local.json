{
  "permissions": {
    "allow": [
      "Bash(git *:*)",
      "Bash(python*:*)",
      "Bash(pip *:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(echo:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(sleep:*)",
      "Bash(cmd /c:*)",
      "Bash(gh *:*)",
      "Bash(TZ=Asia/Seoul date*:*)",
      "Bash(tasklist:*)",
      "Bash(taskkill:*)",
      "Bash(schtasks:*)",
      "Bash(tar:*)",
      "Bash(curl:*)",
      "Bash(powershell -Command Get-Date:*)",
      "Bash(gzip:*)",
      "Bash(dot:*)",
      "Bash(start *:*)",
      "Bash(claude config:*)",
      "Read",
      "WebSearch",
      "WebFetch",
      "mcp__00b6c2d7-87e0-41f1-a983-74975edcd79b__gcal_create_event",
      "mcp__304e7d67-aa0d-47cd-b5c2-f6bcb62cc5d8__notion-update-page",
      "Bash(bash -n \"C:/Users/User/Desktop/업무리스트/.claude/hooks/completion_gate.sh\")",
      "Bash(source .claude/hooks/hook_common.sh)",
      "Bash(hook_log \"Test\" \"hook_log JSON 출력 검증\")",
      "Bash(hook_incident \"compile_fail\" \"auto_compile\" \"/test/example.py\" \"SyntaxError: invalid syntax\")",
      "Bash(bash .claude/hooks/smoke_test.sh)",
      "Bash(bash .claude/hooks/final_check.sh)",
      "Bash(STATE_DIR=\"C:/Users/User/Desktop/업무리스트/.claude/state\")",
      "Bash(mkdir -p \"$STATE_DIR\")",
      "Bash(\"$STATE_DIR/send_gate_passed\")",
      "Bash(bash .claude/hooks/final_check.sh --fast)",
      "Bash(for f:*)",
      "Bash(do echo:*)",
      "Bash(bash -n \"$f\")",
      "Bash(done)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/risk_profile_prompt.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block_dangerous.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/commit_gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/date_scope_guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/evidence_gate.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/protect_files.sh"
          }
        ]
      },
      {
        "matcher": "mcp__Claude_in_Chrome__javascript_tool",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/send_gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto_compile.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/write_marker.sh"
          }
        ]
      },
      {
        "matcher": "Read|Grep|Glob|Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/evidence_mark_read.sh"
          }
        ]
      },
      {
        "matcher": "mcp__Claude_in_Chrome|Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gpt_followup_post.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/notify_slack.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop_guard.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gpt_followup_stop.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/completion_gate.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/evidence_stop_guard.sh"
          }
        ]
      }
    ]
  }
}
