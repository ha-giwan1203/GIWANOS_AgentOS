{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Bash(git *:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(gh *:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(sleep:*)",
      "Bash(TZ=Asia/Seoul date*:*)",
      "Bash(tar:*)",
      "Bash(curl:*)",
      "Bash(gzip:*)",
      "Bash(dot:*)",
      "Bash(source .claude/hooks/*:*)",
      "Bash(bash .claude/hooks/*:*)",
      "Bash(bash -n:*)",
      "Bash(for f:*)",
      "Bash(do echo:*)",
      "Bash(done)",
      "Bash(start *:*)",
      "Bash(claude config:*)",
      "Bash(powershell -Command Get-Date:*)",
      "Bash(tasklist:*)",
      "Bash(schtasks:*)",
      "mcp__00b6c2d7-87e0-41f1-a983-74975edcd79b__gcal_create_event",
      "mcp__304e7d67-aa0d-47cd-b5c2-f6bcb62cc5d8__notion-update-page",
      "Bash(python \"90_공통기준/업무관리/운영검증/scripts/*\":*)",
      "Bash(bash .claude/hooks/smoke_test.sh)",
      "Bash(python3 -c ':*)",
      "Read(//c/Users/User/Desktop/업무리스트/**)",
      "Bash(python3)",
      "Bash(PYTHONUTF8=1 python \"90_공통기준/스킬/youtube-analysis/*\":*)",
      "mcp__304e7d67-aa0d-47cd-b5c2-f6bcb62cc5d8__notion-create-pages",
      "Bash(python -c ':*)",
      "Bash(bash .claude/scripts/hook_registry.sh sync)",
      "mcp__scheduled-tasks__list_scheduled_tasks"
    ],
    "ask": [
      "Bash(python*:*)",
      "Bash(pip *:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(chmod:*)",
      "Bash(cmd /c:*)",
      "Bash(powershell:*)",
      "Bash(taskkill:*)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/precompact_save.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session_start_restore.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/risk_profile_prompt.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block_dangerous.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/commit_gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/date_scope_guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/evidence_gate.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/protect_files.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/state_rebind_check.sh"
          }
        ]
      },
      {
        "matcher": "mcp__Claude_in_Chrome__form_input",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/mcp_send_gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/harness_gate.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/instruction_read_gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto_compile.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/write_marker.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/handoff_archive.sh"
          }
        ]
      },
      {
        "matcher": "Read|Grep|Glob|Bash|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/evidence_mark_read.sh"
          }
        ]
      },
      {
        "matcher": "mcp__Claude_in_Chrome|Bash|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gpt_followup_post.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post_commit_notify.sh",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/notify_slack.sh",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop_guard.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gpt_followup_stop.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/completion_gate.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/evidence_stop_guard.sh"
          }
        ]
      }
    ]
  }
}
