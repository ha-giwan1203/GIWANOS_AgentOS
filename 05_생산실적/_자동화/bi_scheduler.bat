@echo off
powershell -ExecutionPolicy Bypass -Command "$script = Join-Path '%~dp0' 'bi_copy.bat'; Write-Host ''; Write-Host '  BI Auto Copy - Scheduler Setup' -ForegroundColor Cyan; if (-not (Test-Path $script)) { Write-Host '  [ERROR] bi_copy.bat not found' -ForegroundColor Red; Read-Host '  Press Enter'; exit 1 }; schtasks /create /tn 'BI_AutoCopy' /tr ('\"' + $script + '\"') /sc daily /st 07:30 /f; if ($LASTEXITCODE -eq 0) { Write-Host '  [OK] Task registered: BI_AutoCopy (Daily 07:30)' -ForegroundColor Green } else { Write-Host '  [FAIL] Try running as Administrator' -ForegroundColor Red }; Read-Host '  Press Enter'"
