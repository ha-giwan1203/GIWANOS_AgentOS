@echo off
powershell -ExecutionPolicy Bypass -Command "$cfg = [System.IO.File]::ReadAllLines('%~dp0bi_config.txt', [System.Text.Encoding]::UTF8); $src = $cfg[0].Trim(); $dst = $cfg[1].Trim(); Write-Host ''; Write-Host '  BI File Auto Copy' -ForegroundColor Cyan; Write-Host ('  SRC: ' + $src); Write-Host ('  DST: ' + $dst); if (-not (Test-Path $src)) { Write-Host '  [ERROR] Source not found' -ForegroundColor Red; Read-Host '  Press Enter'; exit 1 }; Copy-Item -Path $src -Destination $dst -Force; if ($?) { Unblock-File -Path $dst; Write-Host '  [OK] Copy complete + Unblocked!' -ForegroundColor Green; Write-Host ('  ' + (Get-Date -Format 'yyyy-MM-dd HH:mm:ss')) -ForegroundColor Gray } else { Write-Host '  [FAIL] Copy failed' -ForegroundColor Red }; Read-Host '  Press Enter'"
